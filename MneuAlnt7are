function RenderMainMenu()
    local scrW, scrH = GetScreenResolution()
    local mX, mY, mW, mH = 0.2*scrW, 0.08*scrH, 0.6*scrW, 0.8*scrH

    DrawRect(mX, mY, mW, mH, 0,0,0,220)

    local headerH = 0.12*mH
    DrawRect(mX, mY, mW/3, headerH, 173,216,230,200)
    DrawRect(mX+mW/3, mY, mW/3, headerH, 255,182,193,200)
    DrawRect(mX+2*mW/3, mY, mW/3, headerH, 169,169,169,200)

    SetTextFont(0)
    SetTextScale(0.8,0.8)
    SetTextColour(255,255,255,255)
    SetTextCentre(true)
    SetTextEntry("STRING")
    AddTextComponentString("Main Menu")
    DrawText(mX+mW/2, mY+headerH/2 - 0.01*scrH)

    DrawRect(mX, mY+headerH, mW, 0.002*scrH, 255,255,255,150)

    local listY = mY + headerH + 0.02*scrH
    for i, cat in ipairs(mainCategories) do
        local itemH = 0.05*scrH
        if i == selected then
            DrawRect(mX+0.02*mW, listY, mW-0.04*mW, itemH, 200,0,0,200)
        else
            DrawRect(mX+0.02*mW, listY, mW-0.04*mW, itemH, 30,30,30,150)
        end
        SetTextFont(0)
        SetTextScale(0.4,0.4)
        SetTextColour(255,255,255,255)
        SetTextEntry("STRING")
        AddTextComponentString(cat.name)
        DrawText(mX+0.06*mW, listY+0.01*scrH)
        SetTextEntry("STRING")
        AddTextComponentString(">")
        DrawText(mX+mW-0.06*mW, listY+0.01*scrH)
        listY = listY + itemH + 0.005*scrH
    end

    local bottomY = mY+mH-0.04*scrH
    DrawRect(mX, bottomY, mW, 0.04*scrH, 30,30,30,200)
    SetTextFont(0)
    SetTextScale(0.35,0.35)
    SetTextColour(255,255,255,150)
    SetTextEntry("STRING")
    AddTextComponentString("OSINT Bypass (v1.0.0)")
    DrawText(mX+0.02*mW, bottomY+0.005*scrH)
    SetTextEntry("STRING")
    AddTextComponentString("(10/10)")
    DrawText(mX+mW-0.08*mW, bottomY+0.005*scrH)
end

