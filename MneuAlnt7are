    SetTextFont(0)
    SetTextScale(0.5,0.5)
    SetTextColour(255,255,255,255)
    SetTextCentre(true)
    SetTextEntry("STRING")
    AddTextComponentString(category)
    DrawText(mX+mW/2, mY+0.015*scrH)

    local subs = {}
    for _,c in ipairs(mainCategories) do if c.name==category then subs=c.subs; break end end
    local listY = mY + 0.08*scrH
