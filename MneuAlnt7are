    if flyActive then
        SetEntityVisible(PlayerPedId(), false); SetEntityInvincible(PlayerPedId(), true)
        AddNotif("✈️ Fly ON (W/S/Q/E)", 0,255,255)
    else
        SetEntityVisible(PlayerPedId(), true); SetEntityInvincible(PlayerPedId(), false)
        AddNotif("✈️ Fly OFF", 0,255,255)
    end
end

Citizen.CreateThread(function()
    while true do
        Citizen.Wait(0)
        if flyActive then
            local ped = PlayerPedId()
            SetEntityInvincible(ped, true); SetEntityVisible(ped, false)
            local speed = 8.0
            local forward = GetEntityForwardVector(ped)
            local pos = GetEntityCoords(ped)
            if IsControlPressed(0, 32) then pos = pos + forward * speed end
            if IsControlPressed(0, 33) then pos = pos - forward * speed end
