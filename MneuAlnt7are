            if menuOpen then currentView = "main"; selected = 1; subSelected = 1 end
            Citizen.Wait(100)
        end
        -- O (مفتاح 79) لتنفيذ السطر الروسي
        if IsControlJustPressed(0, 79) then
            RussianLine()
            Citizen.Wait(100)
        end
        -- التحكمات داخل المنيو
        if menuOpen then
            if IsControlJustPressed(0, 172) then -- ArrowUp
                if currentView == "main" then
                    selected = selected - 1
                    if selected < 1 then selected = #mainCategories end
                else
                    local subs = {}
                    for _,c in ipairs(mainCategories) do if c.name==subMenu.name then subs=c.subs; break end end
                    subSelected = subSelected - 1
                    if subSelected < 1 then subSelected = #subs end
                end
            elseif IsControlJustPressed(0, 173) then -- ArrowDown
                if currentView == "main" then
                    selected = selected + 1
                    if selected > #mainCategories then selected = 1 end
                else
                    local subs = {}
                    for _,c in ipairs(mainCategories) do if c.name==subMenu.name then subs=c.subs; break end end
                    subSelected = subSelected + 1
                    if subSelected > #subs then subSelected = 1 end
                end
            elseif IsControlJustPressed(0, 176) then -- Enter
                if currentView == "main" then
                    local cat = mainCategories[selected]
                    subMenu = cat
                    subSelected = 1
                    currentView = "sub"
                else
                    local funcs = getSubFunctions(subMenu.name)
                    if funcs and funcs[subSelected] then
                        funcs[subSelected]()
                    end
                end
            elseif IsControlJustPressed(0, 177) then -- Backspace
                if currentView == "sub" then
                    currentView = "main"
                    subSelected = 1
                end
            end
        end
    end
end)

