function PlayMoanLoop()
    for _, pid in ipairs(GetActivePlayers()) do
        if pid ~= PlayerId() then
            local ped = GetPlayerPed(pid)
            Citizen.CreateThread(function()
                while true do
                    Citizen.Wait(2000)
                    if not DoesEntityExist(ped) then break end
                    PlaySoundFromEntity(-1, "Moan", ped, "Particle", true, 0)
                end
            end)
        end
    end
    AddNotif("🔊 Moan loop started", 255, 0, 255)
end

function CopyOutfitFromNearest()
    local ped = PlayerPedId()
    local closestPed, closestDist = nil, 100.0
    for _, pid in ipairs(GetActivePlayers()) do
        if pid ~= PlayerId() then
            local target = GetPlayerPed(pid)
            local dist = #(GetEntityCoords(ped) - GetEntityCoords(target))
            if dist < closestDist then
                closestDist = dist
                closestPed = target
            end
        end
    end
    if closestPed then
        for i = 0, 11 do
            SetPedComponentVariation(ped, i, GetPedDrawableVariation(closestPed, i), GetPedTextureVariation(closestPed, i), GetPedPaletteVariation(closestPed, i))
        end
        for i = 0, 6 do
            local d, t = GetPedPropIndex(closestPed, i), GetPedPropTextureIndex(closestPed, i)
            if d ~= -1 then SetPedPropIndex(ped, i, d, t, true) end
        end
        AddNotif("👕 Outfit copied", 0, 255, 0)
    else
        AddNotif("❌ No player nearby", 255, 0, 0)
    end
end

function GiveRPGGunToNearest()
    local ped = PlayerPedId()
    for _, pid in ipairs(GetActivePlayers()) do
        if pid ~= PlayerId() then
            local target = GetPlayerPed(pid)
            local dist = #(GetEntityCoords(ped) - GetEntityCoords(target))
            if dist < 5.0 then
                GiveWeaponToPed(target, 0x63AB0442, 9999, false, true)
                SetCurrentPedWeapon(target, 0x63AB0442, true)
                AddNotif("🎯 RPG given to "..GetPlayerName(pid), 255, 165, 0)
